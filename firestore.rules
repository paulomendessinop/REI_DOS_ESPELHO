rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Config collection rules (public read and write)
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }

    // Images collection rules (public read, server-only write)
    match /images/{imageId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
